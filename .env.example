# Prisma database URL (SQLite for local dev; use Turso/Postgres in production)
DATABASE_URL="file:./dev.db"

# Budget login credentials (never commit real values — set in Vercel env)
BUDGET_ADMIN_EMAIL="hutsonosler@gmail.com"
# On Vercel, paste the hash without escapes. Locally, escape each $ as \$ for Next.js.
BUDGET_ADMIN_PASSWORD_HASH="\$2b\$12\$..."

# Session signing secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
AUTH_SECRET=""
