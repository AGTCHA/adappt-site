# Prisma database URL
# Local dev:
DATABASE_URL="file:./dev.db"
# EC2 production (persistent SQLite on disk):
# DATABASE_URL="file:./prisma/prod.db"

# Turso — only needed for Vercel/serverless; skip on EC2
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Budget login — set ALL of these on Vercel / EC2
BUDGET_ADMIN_EMAIL="hutsonosler@gmail.com"
# Option A (simplest for Vercel): plain password env var
BUDGET_ADMIN_PASSWORD=""
# Option B: bcrypt hash (on Vercel paste WITHOUT backslashes)
# BUDGET_ADMIN_PASSWORD_HASH="$2b$12$..."

# Session signing secret
AUTH_SECRET=""
